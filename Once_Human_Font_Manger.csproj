<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>Once_Human_Font_Manger</AssemblyName>
    <RootNamespace>OnceHumanFontManager</RootNamespace>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <ApplicationIcon>icon.ico</ApplicationIcon>
  </PropertyGroup>

  <Target Name="AutoPublish" AfterTargets="Build" Condition="'$(Configuration)' == 'Release' and '$(NoAutoPublish)' != 'true' and '$(_IsPublishing)' != 'true'">
    <Exec Command="dotnet publish &quot;$(MSBuildProjectFullPath)&quot; -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true -p:IncludeNativeLibrariesForSelfExtract=true -p:DebugType=None -p:DebugSymbols=false -p:NoAutoPublish=true -o &quot;$(MSBuildProjectDirectory)\bin\Release\Publish&quot;" />
  </Target>

  <ItemGroup>
    <Content Include="icon.ico" />
  </ItemGroup>

</Project>
